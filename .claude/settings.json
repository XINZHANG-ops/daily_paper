{
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "denyRead": ["~/"],
      "allowRead": ["."]
    }
  },
  "permissions": {
    "deny": [
      "Read(~/**)",
      "Glob(~/**)",
      "Grep(~/**)"
    ],
    "allow": [
      "Read(./**)",
      "Glob(./**)",
      "Grep(./**)",
      "Edit(./**)",
      "Write(./**)",
      "Bash(*)"
    ]
  }
}
